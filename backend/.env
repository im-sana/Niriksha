# ============================================================
# Niriksha Backend — Environment Configuration
# ============================================================

# MongoDB Connection (change for production)
MONGODB_URL=mongodb://localhost:27017
DB_NAME=niriksha

# JWT Configuration
# IMPORTANT: Change JWT_SECRET to a strong random string in production!
JWT_SECRET=niriksha_super_secret_key_change_in_production_2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Anthropic Claude API
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Screenshot storage directory (relative to backend/)
SCREENSHOTS_DIR=screenshots

# YOLO model file for multi-face and phone detectors (relative to backend/)
YOLO_MODEL_PATH=yolo26n.pt
